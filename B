-- Main AI Loop
task.spawn(function()
    local lastCheckTime = 0
    local ballBeforeParry = nil
    local velocityBeforeParry = nil
    
    RunService.Heartbeat:Connect(function()
        if not autoParryEnabled then return end
        if tick() - lastCheckTime < 0.01 then return end
        
        local Ball = FindBall()
        if not Ball then 
            hasParried = false
            return 
        end
        
        local BallVelocity = Ball.AssemblyLinearVelocity
        local BallSpeed = BallVelocity.Magnitude
        local Distance = local_player:DistanceFromCharacter(Ball.Position)
        
        -- AI: Calculate time to impact
        local TimeToImpact = Distance / math.max(BallSpeed, 1)
        
        -- Check if we already parried this ball approach
        if not IsTheTarget() then
            hasParried = false
            
            -- AI: Check if previous parry was successful
            if ballBeforeParry and velocityBeforeParry then
                local success = CheckParrySuccess(ballBeforeParry, velocityBeforeParry)
                AI_Learn(success, BallSpeed, Distance)
                ballBeforeParry = nil
                velocityBeforeParry = nil
            end
            
            lastCheckTime = tick()
            return
        end
        
        -- AI: Parry when ball is within learned threshold
        if not hasParried and TimeToImpact <= AI.currentThreshold and BallSpeed > 5 then
            if PerformParry() then
                hasParried = true
                ballBeforeParry = Ball
                velocityBeforeParry = BallVelocity
            end
        end
        
        lastCheckTime = tick()
    end)
end)
