-- AI: Adjust parry timing based on success/failure
local function AI_Learn(success, ballSpeed, distance)
    table.insert(AI.parryHistory, {
        success = success,
        speed = ballSpeed,
        distance = distance,
        threshold = AI.currentThreshold,
        time = tick()
    })
    
    -- Keep only last 20 records
    if #AI.parryHistory > 20 then
        table.remove(AI.parryHistory, 1)
    end
    
    if success then
        AI.consecutiveHits = AI.consecutiveHits + 1
        AI.consecutiveMisses = 0
        
        -- If hitting consistently, try to parry closer (more precise)
        if AI.consecutiveHits >= 3 then
            AI.currentThreshold = math.max(0.25, AI.currentThreshold - 0.02)
        end
    else
        AI.consecutiveMisses = AI.consecutiveMisses + 1
        AI.consecutiveHits = 0
        
        -- If missing, parry earlier (safer)
        if AI.consecutiveMisses >= 2 then
            AI.currentThreshold = math.min(1.2, AI.currentThreshold + 0.05)
        end
    end
    
    -- Adjust based on ball speed (faster balls = earlier parry)
    if ballSpeed > 100 then
        AI.currentThreshold = math.min(1.2, AI.currentThreshold + 0.05)
    elseif ballSpeed < 50 then
        AI.currentThreshold = math.max(0.25, AI.currentThreshold - 0.02)
    end
    
    -- Update orb size to match AI threshold (visual feedback)
    orbSize = AI.currentThreshold * 50
end

