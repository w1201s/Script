local function FindBall()
    for _, ball in pairs(workspace:WaitForChild("Balls"):GetChildren()) do
        if ball:GetAttribute("realBall") == true then
            return ball
        end
    end
end

local function IsTheTarget()
    return local_player.Character and local_player.Character:FindFirstChild("Highlight")
end

local lastParryTime = 0
local lastBallPosition = nil
local hasParried = false

local function PerformParry()
    if tick() - lastParryTime >= 0.15 then
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        lastParryTime = tick()
        return true
    end
    return false
end

-- AI: Detect if parry was successful (ball bounced back)
local function CheckParrySuccess(ball, previousVelocity)
    -- If ball velocity reversed after parry, it was successful
    if ball and ball.AssemblyLinearVelocity then
        local newVelocity = ball.AssemblyLinearVelocity
        if previousVelocity and newVelocity then
            local dot = previousVelocity.Unit:Dot(newVelocity.Unit)
            if dot < -0.5 then -- Direction reversed
                return true
            end
        end
    end
    return false
end

