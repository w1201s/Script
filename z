-- Simple Hitbox Expander - No Collision Issues
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Hitbox",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "by we fucking dead",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "Hitbox",
        FileName = "Settings"
    },
    KeySystem = false
})

local MainTab = Window:CreateTab("Main", 4483362458)

-- Settings
local Enabled = false
local Size = 10
local Transparency = 0.7
local SelfHitbox = false

MainTab:CreateToggle({
    Name = "Enable",
    CurrentValue = false,
    Flag = "Enable",
    Callback = function(Value)
        Enabled = Value
        if not Value then
            -- Reset all
            for _, plr in ipairs(game.Players:GetPlayers()) do
                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = plr.Character.HumanoidRootPart
                    hrp.Size = Vector3.new(2, 2, 1)
                    hrp.Transparency = 1
                    hrp.CanCollide = false
                    hrp.CanQuery = true
                end
            end
        end
    end
})

MainTab:CreateSlider({
    Name = "Size",
    Range = {2, 20},
    Increment = 1,
    CurrentValue = 10,
    Flag = "Size",
    Callback = function(Value)
        Size = Value
    end
})

MainTab:CreateSlider({
    Name = "Transparency",
    Range = {0, 1},
    Increment = 0.1,
    CurrentValue = 0.7,
    Flag = "Trans",
    Callback = function(Value)
        Transparency = Value
    end
})

MainTab:CreateToggle({
    Name = "Include Self",
    CurrentValue = false,
    Flag = "Self",
    Callback = function(Value)
        SelfHitbox = Value
    end
})

-- Main loop
game:GetService("RunService").RenderStepped:Connect(function()
    if not Enabled then return end
    
    local localPlayer = game.Players.LocalPlayer
    
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr == localPlayer and not SelfHitbox then continue end
        
        if plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            
            if hrp and hum and hum.Health > 0 then
                -- Apply hitbox
                hrp.Size = Vector3.new(Size, Size, Size)
                hrp.Transparency = Transparency
                hrp.Color = Color3.fromRGB(255, 0, 0)
                hrp.Material = Enum.Material.Neon
                
                -- CRITICAL: No collision settings
                hrp.CanCollide = false
                hrp.CanQuery = true
                hrp.Massless = true
            end
        end
    end
end)

-- Handle new players
game.Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function(char)
        if not Enabled then return end
        task.wait(0.5)
        
        local hrp = char:WaitForChild("HumanoidRootPart", 2)
        local hum = char:WaitForChild("Humanoid", 2)
        
        if hrp and hum then
            hrp.Size = Vector3.new(Size, Size, Size)
            hrp.Transparency = Transparency
            hrp.Color = Color3.fromRGB(255, 0, 0)
            hrp.Material = Enum.Material.Neon
            hrp.CanCollide = false
            hrp.CanQuery = true
            hrp.Massless = true
        end
    end)
end)

Rayfield:Notify({
    Title = "Loaded",
    Content = "No collision | CanCollide = false",
    Duration = 3
})
