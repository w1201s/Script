    Flag = "HitboxColor",
    Callback = function(Color)
        HitboxColor = Color
    end
})

-- Team Check
MainTab:CreateToggle({
    Name = "Team Check",
    CurrentValue = true,
    Flag = "TeamCheck",
    Callback = function(Value)
        TeamCheck = Value
    end
})

-- Update local character
local function updateLocalChar()
    local player = game.Players.LocalPlayer
    if player then
        LocalCharacter = player.Character
        player.CharacterAdded:Connect(function(char)
            LocalCharacter = char
        end)
    end
end
updateLocalChar()

-- Check if ignored path
local function isIgnored(obj)
    if not IGNORE_PATH then return false end
    local current = obj
    while current do
        if current == IGNORE_PATH then return true end
        current = current.Parent
    end
    return false
end

-- Check if local player
local function isLocalPlayer(character)
    return character == LocalCharacter
end

-- Get humanoid
local function getHumanoid(model)
    if not model or not model:IsA("Model") then return nil end
    return model:FindFirstChildOfClass("Humanoid")
end

-- Create hitbox (COMPLETELY DETACHED)
local function createHitbox(character)
    if not HitboxEnabled or not HitboxFolder then return end
    if not character or not character.Parent then return end
    if HitboxData[character] then return end -- Already exists
    
    -- Skip self
    if isLocalPlayer(character) then return end
    
    -- Ignore check
    if isIgnored(character) then return end
    
    -- Must have humanoid
    local humanoid = getHumanoid(character)
    if not humanoid or humanoid.Health <= 0 then return end
    
    -- Team check
    if TeamCheck then
        local localPlayer = game.Players.LocalPlayer
        local player = game.Players:GetPlayerFromCharacter(character)
        if player and localPlayer and player.Team == localPlayer.Team then
            return
        end
    end
    
    -- Get target part
    local targetPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Head")
    if not targetPart then return end
    
    -- Create completely separate part in workspace folder
    local hitbox = Instance.new("Part")
    hitbox.Name = character.Name .. "_Hitbox"
    hitbox.Shape = Enum.PartType.Ball
    hitbox.Material = Enum.Material.ForceField
    hitbox.CanCollide = false
    hitbox.CanQuery = true
    hitbox.Massless = true
    hitbox.Anchored = true -- ANCHORED = ZERO physics impact
    hitbox.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
    hitbox.Transparency = HitboxTransparency
    hitbox.Color = HitboxColor
    hitbox.Parent = HitboxFolder
    
    -- Position at target
    hitbox.CFrame = targetPart.CFrame
    
    -- Store data
    HitboxData[character] = {
        part = hitbox,
        target = targetPart,
        humanoid = humanoid
    }
    
    -- Cleanup on death
    humanoid.Died:Connect(function()
        if HitboxData[character] then
            HitboxData[character].part:Destroy()
            HitboxData[character] = nil
        end
    end)
end

-- Main update loop (CFrame only, no parenting/welds)
local RunService = game:GetService("RunService")

RunService.Heartbeat:Connect(function()
    if not HitboxEnabled then return end
    
    -- Update positions and cleanup
    for character, data in pairs(HitboxData) do
        local hitbox = data.part
        local target = data.target
        local humanoid = data.humanoid
        
        -- Validate
        if not character or not character.Parent or not hitbox or not hitbox.Parent then
            if hitbox then hitbox:Destroy() end
            HitboxData[character] = nil
            continue
        end
        
        -- Check alive
        if not humanoid or humanoid.Health <= 0 then
            hitbox:Destroy()
            HitboxData[character] = nil
            continue
        end
        
        -- Update position (CFrame only - no physics connection)
        if target and target.Parent then
            hitbox.CFrame = target.CFrame
        else
            -- Target lost, remove
            hitbox:Destroy()
            HitboxData[character] = nil
        end
    end
    
    -- Find new characters
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and not HitboxData[obj] then
            local humanoid = getHumanoid(obj)
            if humanoid and humanoid.Health > 0 then
                createHitbox(obj)
            end
        end
    end
end)

-- Handle new spawns
workspace.DescendantAdded:Connect(function(obj)
    if not HitboxEnabled then return end
    if obj:IsA("Model") then
        task.delay(0.1, function()
            local humanoid = getHumanoid(obj)
            if humanoid and humanoid.Health > 0 then
                createHitbox(obj)
            end
        end)
    end
end)

-- Cleanup on remove
workspace.DescendantRemoving:Connect(function(obj)
    if HitboxData[obj] then
        HitboxData[obj].part:Destroy()
        HitboxData[obj] = nil
    end
end)

Rayfield:Notify({
    Title = "Hitbox Loaded",
    Content = "ZERO physics impact | Anchored | Detached",
    Duration = 5
})
