function GetCharacter(target)
    if not target then return nil end
    if target:IsA("Player") then
        return target.Character
    end
    return target
end

function IsAlive(character)
    if not character then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health > 0
end

function GetHRP(character)
    if not character then return nil end
    return character:FindFirstChild("HumanoidRootPart") 
        or character:FindFirstChild("Torso") 
        or character:FindFirstChild("UpperTorso")
end

--// SHARED IGNORE FUNCTION for both Auto Farm and Walk Path
function IsIgnored(model)
    if not model then return true end
    if model.Name == "R6n_w1201s" then return true end
    -- Check shared ignore list
    for _, name in ipairs(CONFIG.IgnoreList) do
        if model.Name == name or (model.Parent and model.Parent.Name == name) then
            return true
        end
    end
    local everything = Workspace:FindFirstChild("Everything")
    if everything and model:IsDescendantOf(everything) then
        if model.Parent and model.Parent.Name == "Npc" then
            return true
        end
    end
    return false
end

function IsValidTarget(target)
    local char = GetCharacter(target)
    if not char then return false end
    if IsIgnored(char) then return false end
    
    local hrp = GetHRP(char)
    if not hrp then return false end
    if hrp.Position.Y < CONFIG.IgnoreY then return false end
    
    return IsAlive(char)
end

function GetAllTargets()
    local all = {}
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and IsValidTarget(player) then
            table.insert(all, player)
        end
    end
    
    for _, model in ipairs(Workspace:GetDescendants()) do
        if model:IsA("Model") and not Players:GetPlayerFromCharacter(model) then
            if not IsIgnored(model) and IsValidTarget(model) then
                table.insert(all, model)
            end
        end
    end
    
    return all
end

function GetNextTarget()
    local targets = GetAllTargets()
    if #targets == 0 then return nil end
    
    if CurrentTarget then
        for i, t in ipairs(targets) do
            if t == CurrentTarget then
                local nextTarget = targets[i + 1] or targets[1]
                if IsValidTarget(nextTarget) then return nextTarget end
            end
        end
    end
    
    for _, t in ipairs(targets) do
        if IsValidTarget(t) then return t end
    end
    
    return nil
end

function CalculatePosition(targetHRP)
    if not targetHRP then return nil end
    
    local targetPos = targetHRP.Position
    local targetCFrame = targetHRP.CFrame
    local pos = CONFIG.Position
    local dist = CONFIG.Distance
    
    if pos == "Under" then
        return targetPos - Vector3.new(0, dist, 0)
    elseif pos == "Above" then
        return targetPos + Vector3.new(0, dist, 0)
    elseif pos == "Behind" then
        return targetPos - (targetCFrame.LookVector * dist)
    elseif pos == "Front" then
        return targetPos + (targetCFrame.LookVector * dist)
    elseif pos == "Left" then
        return targetPos - (targetCFrame.RightVector * dist)
    elseif pos == "Right" then
        return targetPos + (targetCFrame.RightVector * dist)
    elseif pos == "Orbit" then
        OrbitAngle = OrbitAngle + (CONFIG.OrbitSpeed * 0.001)
        return targetPos + Vector3.new(
            math.cos(OrbitAngle) * dist,
            0,
            math.sin(OrbitAngle) * dist
        )
    end
    return targetPos
end

function SmoothFollow()
    if not CurrentTarget or not IsValidTarget(CurrentTarget) then
        CurrentTarget = GetNextTarget()
        if not CurrentTarget then return end
    end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local myHRP = GetHRP(char)
    if not myHRP then return end
    
    local targetChar = GetCharacter(CurrentTarget)
    local targetHRP = GetHRP(targetChar)
    if not targetHRP then
        CurrentTarget = GetNextTarget()
        return
    end
    
    local targetPos = CalculatePosition(targetHRP)
    if not targetPos then return end
    
    local direction = targetPos - myHRP.Position
    local distance = direction.Magnitude
    
    if distance > 0.5 then
        local speed = distance / CONFIG.Smoothness
        myHRP.Velocity = direction.Unit * math.min(speed, 1000)
    else
        myHRP.Velocity = Vector3.new(0, 0, 0)
    end
    
    myHRP.CFrame = CFrame.new(myHRP.Position, targetHRP.Position)
end

function CreateAntiVoid()
    local existing = Workspace:FindFirstChild("AntiVoid")
    if existing then return end
    
    local part = Instance.new("Part")
    part.Name = "AntiVoid"
    part.Size = Vector3.new(10000, 3, 10000)
    part.Position = Vector3.new(0, CONFIG.IgnoreY - 1, 0)
    part.Anchored = true
    part.CanCollide = true
    part.Transparency = 0.6
    part.Color = Color3.fromRGB(255, 0, 255)
    part.Material = Enum.Material.Neon
    part.Parent = Workspace
end

function DestroyAntiVoid()
    local existing = Workspace:FindFirstChild("AntiVoid")
    if existing then
        existing:Destroy()
    end
end

function GetTool()
    local character = LocalPlayer.Character
    if not character then return nil end
    
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Tool") then
            return child
        end
    end
    return nil
end

function GetToolFromBackpack()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return nil end
    
    local glovesFolder = backpack:FindFirstChild("Gloves")
    if glovesFolder then
        for _, glove in ipairs(glovesFolder:GetChildren()) do
            if glove:IsA("Tool") then
                return glove
            end
        end
    end
    
    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            return tool
        end
    end
    return nil
end

function EquipTool()
    local currentTime = tick()
    if currentTime - LastEquipTime < EquipCooldown then return nil end
    
    local character = LocalPlayer.Character
    if not character then return nil end
    
    local currentTool = GetTool()
    if currentTool then return currentTool end
    
    local tool = GetToolFromBackpack()
    if tool then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid:EquipTool(tool)
            LastEquipTime = currentTime
            return tool
        end
    end
    return nil
end

function DestroyTargetHitbox()
    for _, part in ipairs(TargetHitboxParts) do
        if part then part:Destroy() end
    end
    TargetHitboxParts = {}
end

function CreateTargetHitbox(target)
    if not CONFIG.HitboxEnabled then return end
    
    DestroyTargetHitbox()
    
    if not target then return end
    
    local char = GetCharacter(target)
    if not char then return end
    
    local hrp = GetHRP(char)
    if not hrp then return end
    
    for i = 1, CONFIG.LayerCount do
        local size = CONFIG.HitboxSize + (i * CONFIG.LayerSpacing)
        
        local hitbox = Instance.new("Part")
        hitbox.Name = "TargetHitbox_" .. i
        hitbox.Shape = Enum.PartType.Ball
        hitbox.Size = Vector3.new(size * 2, size * 2, size * 2)
        hitbox.Anchored = false
        hitbox.CanCollide = false
        hitbox.Transparency = CONFIG.VisualHitbox and 0.6 or 1
        hitbox.Color = i == 1 and CONFIG.HitboxColor or Color3.fromRGB(255, 100 + (i * 20), 0)
        hitbox.Material = Enum.Material.ForceField
        
        local weld = Instance.new("Weld")
        weld.Part0 = hrp
        weld.Part1 = hitbox
        weld.Parent = hitbox
        
        hitbox.Parent = char
        table.insert(TargetHitboxParts, hitbox)
    end
end

function UpdateTargetHitbox()
    if not CONFIG.HitboxEnabled then
        DestroyTargetHitbox()
        return
    end
    
    if not CurrentTarget or not IsValidTarget(CurrentTarget) then
        CurrentTarget = GetNextTarget()
        if not CurrentTarget then
            DestroyTargetHitbox()
            return
        end
    end
    
    if #TargetHitboxParts == 0 then
        CreateTargetHitbox(CurrentTarget)
        return
    end
    
    local char = GetCharacter(CurrentTarget)
    if not char then
        DestroyTargetHitbox()
        CreateTargetHitbox(CurrentTarget)
        return
    end
    
    for i, part in ipairs(TargetHitboxParts) do
        if not part or not part.Parent then
            CreateTargetHitbox(CurrentTarget)
            return
        end
        
        local expectedSize = CONFIG.HitboxSize + (i * CONFIG.LayerSpacing)
        if part.Size.X ~= expectedSize * 2 then
            part.Size = Vector3.new(expectedSize * 2, expectedSize * 2, expectedSize * 2)
        end
        
        if CONFIG.VisualHitbox then
            if part.Transparency > 0.7 then part.Transparency = 0.6 end
        else
            if part.Transparency < 1 then part.Transparency = 1 end
        end
    end
end

function CheckIfInTargetHitbox()
    if not CONFIG.HitboxEnabled then return nil, 0 end
    
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    
    local myHRP = GetHRP(myChar)
    if not myHRP then return nil end
    
    local myPos = myHRP.Position
    
    for i, hitboxPart in ipairs(TargetHitboxParts) do
        if not hitboxPart or not hitboxPart.Parent then continue end
        
        local distance = (myPos - hitboxPart.Position).Magnitude
        local layerSize = CONFIG.HitboxSize + (i * CONFIG.LayerSpacing)
        
        if distance <= layerSize then
            if CONFIG.VisualHitbox then
                hitboxPart.Color = Color3.fromRGB(0, 255, 0)
                task.delay(0.1, function()
                    if hitboxPart and hitboxPart.Parent then
                        hitboxPart.Color = i == 1 and CONFIG.HitboxColor or Color3.fromRGB(255, 100 + (i * 20), 0)
                    end
                end)
            end
            
            return CurrentTarget, i
        end
    end
    
    return nil, 0
end

--// Walk Path System - Uses SAME IsIgnored function
function GenerateWalkPathPoints()
    WalkPathPoints = {}
    
    local myChar = LocalPlayer.Character
    if not myChar then return end
    
    local myHRP = GetHRP(myChar)
    if not myHRP then return end
    
    local myPos = myHRP.Position
    local radius = CONFIG.WalkPathRadius
    
    -- Find all valid targets (anything with a position)
    local allPoints = {}
    
    -- Get players
    if CONFIG.WalkPathType == "All" or CONFIG.WalkPathType == "Players" then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local char = player.Character
                if char and not IsIgnored(char) then  -- Use shared IsIgnored
                    local hrp = GetHRP(char)
                    if hrp then
                        local dist = (hrp.Position - myPos).Magnitude
                        if dist <= radius and hrp.Position.Y >= CONFIG.IgnoreY then
                            table.insert(allPoints, {
                                Position = hrp.Position,
                                Instance = char,
                                Type = "Player",
                                Distance = dist
                            })
                        end
                    end
                end
            end
        end
    end
    
    -- Get NPCs/Models (anything with position)
    if CONFIG.WalkPathType == "All" or CONFIG.WalkPathType == "NPCs" then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then
                if not IsIgnored(obj) then  -- Use shared IsIgnored
                    local primary = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso") or obj.PrimaryPart
                    if primary then
                        local dist = (primary.Position - myPos).Magnitude
                        if dist <= radius and primary.Position.Y >= CONFIG.IgnoreY then
                            local humanoid = obj:FindFirstChildOfClass("Humanoid")
                            if not humanoid or humanoid.Health > 0 then
                                table.insert(allPoints, {
                                    Position = primary.Position,
                                    Instance = obj,
                                    Type = "NPC",
                                    Distance = dist
                                })
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- Sort by distance
    table.sort(allPoints, function(a, b)
        return a.Distance < b.Distance
    end)
    
    -- Use pathfinding to validate paths
    local validPaths = {}
    local maxPaths = math.min(CONFIG.WalkPathMaxPaths, #allPoints)
    
    for i = 1, #allPoints do
        if #validPaths >= maxPaths then break end
        
        local point = allPoints[i]
        local path = PathfindingService:CreatePath({
            AgentRadius = 2,
            AgentHeight = 5,
            AgentCanJump = CONFIG.WalkPathJumpEnabled,
            AgentJumpHeight = 10,
            AgentMaxSlope = 45,
            WaypointSpacing = 4
        })
        
        local success = pcall(function()
            path:ComputeAsync(myPos, point.Position)
        end)
        
        if success and path.Status == Enum.PathStatus.Success then
            table.insert(validPaths, {
                Position = point.Position,
                Instance = point.Instance,
                Type = point.Type,
                Path = path,
                Waypoints = path:GetWaypoints(),
                Distance = point.Distance
            })
        end
        
        if i % 50 == 0 then
            task.wait(0.01)
        end
    end
    
    WalkPathPoints = validPaths
    print("Generated " .. #WalkPathPoints .. " valid walk paths")
end

function WalkPathToNextPoint()
    if not CONFIG.WalkPathEnabled then return end
    if #WalkPathPoints == 0 then
        GenerateWalkPathPoints()
        if #WalkPathPoints == 0 then return end
    end
    
    local myChar = LocalPlayer.Character
    if not myChar then return end
    
    local myHumanoid = myChar:FindFirstChildOfClass("Humanoid")
    if not myHumanoid then return end
    
    local currentPoint = WalkPathPoints[WalkPathCurrentIndex]
    if not currentPoint then
        WalkPathCurrentIndex = 1
        currentPoint = WalkPathPoints[1]
        if not currentPoint then return end
    end
    
    -- Check if target is still valid (not ignored)
    if currentPoint.Instance and IsIgnored(currentPoint.Instance) then
        WalkPathCurrentIndex = WalkPathCurrentIndex + 1
        if WalkPathCurrentIndex > #WalkPathPoints then
            WalkPathCurrentIndex = 1
        end
        return
    end
    
    local myHRP = GetHRP(myChar)
    if myHRP then
        local dist = (myHRP.Position - currentPoint.Position).Magnitude
        if dist < 5 then
            WalkPathCurrentIndex = WalkPathCurrentIndex + 1
            if WalkPathCurrentIndex > #WalkPathPoints then
                WalkPathCurrentIndex = 1
                GenerateWalkPathPoints()
            end
            return
        end
    end
    
    local waypoints = currentPoint.Waypoints
    if waypoints and #waypoints > 1 then
        local nextWaypointIndex = 2
        for i = 2, #waypoints do
            local wp = waypoints[i]
            if myHRP then
                local dist = (myHRP.Position - wp.Position).Magnitude
                if dist > 3 then
                    nextWaypointIndex = i
                    break
                end
            end
        end
        
        local nextWaypoint = waypoints[nextWaypointIndex]
        if nextWaypoint then
            myHumanoid:MoveTo(nextWaypoint.Position)
            
            if nextWaypoint.Action == Enum.PathWaypointAction.Jump and CONFIG.WalkPathJumpEnabled then
                myHumanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    else
        myHumanoid:MoveTo(currentPoint.Position)
    end
end

function DoWalkPath()
    if not CONFIG.WalkPathEnabled then return end
    WalkPathToNextPoint()
end

--// FIXED: Tool activation with better checks
function DoHit()
    local success, err = pcall(function()
        -- Handle Auto Farm movement
        if CONFIG.AutoFarm then
            Workspace.Gravity = 0
            SmoothFollow()
        else
            Workspace.Gravity = OriginalGravity
        end
        
        -- Handle Hitbox and AntiVoid
        if CONFIG.Enabled then
            CreateAntiVoid()
            UpdateTargetHitbox()
        end
        
        -- FIXED: Better tool handling
        local tool = GetTool()
        if not tool then
            tool = EquipTool()
        end
        
        if tool and tool.Parent == LocalPlayer.Character then
            local target, layer = CheckIfInTargetHitbox()
            if target then
                -- FIXED: Multiple activation methods for compatibility
                if tool.Activate then
                    tool:Activate()
                end
                
                -- Alternative: Check for custom activation events
                if tool:FindFirstChild("ActivateEvent") then
                    tool.ActivateEvent:Fire()
                end
                
                -- Alternative: Check for RemoteEvent in tool
                local remote = tool:FindFirstChildOfClass("RemoteEvent")
                if remote then
                    remote:FireServer()
                end
                
                -- Alternative: Check for BindableEvent
                local bindable = tool:FindFirstChildOfClass("BindableEvent")
                if bindable then
                    bindable:Fire()
                end
            end
        end
    end)
    
    if not success then
        warn("DoHit Error: " .. tostring(err))
    end
end

