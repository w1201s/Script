-- Key Validation
local function validateKey()
    local enteredKey = KeyInput.Text:gsub("%s+", "") -- Remove whitespace
    
    if enteredKey == "" then
        StatusLabel.Text = "⚠️ Please enter a key"
        StatusLabel.TextColor3 = CONFIG.ErrorColor
        StatusLabel.Visible = true
        
        -- Shake animation
        local originalPos = TextBoxContainer.Position
        tween(TextBoxContainer, {Position = UDim2.new(0, 25, 0, 85)}, 0.05).Completed:Connect(function()
            tween(TextBoxContainer, {Position = UDim2.new(0, 15, 0, 85)}, 0.05).Completed:Connect(function()
                tween(TextBoxContainer, {Position = originalPos}, 0.05)
            end)
        end)
        
        tween(TextBoxStroke, {Color = CONFIG.ErrorColor}, 0.2)
        wait(0.5)
        tween(TextBoxStroke, {Color = CONFIG.AccentColor}, 0.3)
        return
    end
    
    if enteredKey == CONFIG.Key then
        -- Success!
        StatusLabel.Text = "✅ Key accepted! Loading..."
        StatusLabel.TextColor3 = CONFIG.SuccessColor
        StatusLabel.Visible = true
        
        tween(SubmitButton, {BackgroundColor3 = CONFIG.SuccessColor}, 0.3)
        tween(TextBoxStroke, {Color = CONFIG.SuccessColor}, 0.3)
        
        wait(1)
        
        -- Success animation and close
        tween(MainFrame, {
            Size = UDim2.new(0, 450, 0, 350),
            BackgroundTransparency = 0.5
        }, 0.2)
        
        wait(0.2)
        
        tween(MainFrame, {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            BackgroundTransparency = 1
        }, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In).Completed:Connect(function()
            KeySystem:Destroy()
            print("Key system passed! Load your script here.")
            -- ADD YOUR MAIN SCRIPT HERE
        end)
    else
        -- Wrong key
        StatusLabel.Text = "❌ Invalid key! Check Discord for the correct key."
        StatusLabel.TextColor3 = CONFIG.ErrorColor
        StatusLabel.Visible = true
        
        -- Shake animation
        local originalPos = TextBoxContainer.Position
        for i = 1, 3 do
            tween(TextBoxContainer, {Position = UDim2.new(0, 25, 0, 85)}, 0.05).Completed:Wait()
            tween(TextBoxContainer, {Position = UDim2.new(0, 15, 0, 85)}, 0.05).Completed:Wait()
        end
        tween(TextBoxContainer, {Position = originalPos}, 0.05)
        
        tween(TextBoxStroke, {Color = CONFIG.ErrorColor}, 0.2)
        KeyInput.Text = ""
        wait(0.5)
        tween(TextBoxStroke, {Color = CONFIG.AccentColor}, 0.3)
    end
end

SubmitButton.MouseButton1Click:Connect(validateKey)

