-- Function to fire proximity prompt multiple times in a loop
local function firePromptLoop(obj, duration)
    if not obj then return end
    local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
    if not prompt then return end
    
    local startTime = tick()
    while tick() - startTime < duration do
        fireproximityprompt(prompt)
        task.wait(0.05)  -- Fire every 0.05 seconds
    end
end

-- Function to tween to position
local function tweenTo(position)
    local player = game.Players.LocalPlayer
    local character = player.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        local hrp = character.HumanoidRootPart
        local distance = (position - hrp.Position).Magnitude
        local tweenTime = distance / tweenSpeed
        
        local tweenInfo = TweenInfo.new(
            tweenTime,
            Enum.EasingStyle.Linear,
            Enum.EasingDirection.Out
        )
        
        local goal = {CFrame = CFrame.new(position)}
        local tween = game:GetService("TweenService"):Create(hrp, tweenInfo, goal)
        tween:Play()
        tween.Completed:Wait()
    end
end

-- Function to teleport instantly
local function teleportTo(position)
    local player = game.Players.LocalPlayer
    local character = player.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        character.HumanoidRootPart.CFrame = CFrame.new(position)
    end
end

-- Auto Farm Function
local function startAutoFarm()
    while isFarming do
        local activeBrainrots = workspace:FindFirstChild("ActiveBrainrots")
        local zones = workspace:FindFirstChild("Zones")
        
        if activeBrainrots then
            for _, brainrot in ipairs(activeBrainrots:GetChildren()) do
                if not isFarming then break end
                
                local targetPos = nil
                
                -- Get target position
                if brainrot and brainrot:IsA("Model") and brainrot:FindFirstChild("HumanoidRootPart") then
                    targetPos = brainrot.HumanoidRootPart.Position
                elseif brainrot and brainrot:IsA("BasePart") then
                    targetPos = brainrot.Position
                elseif brainrot then
                    local part = brainrot:FindFirstChildWhichIsA("BasePart")
                    if part then
                        targetPos = part.Position
                    end
                end
                
                -- TP to brainrot (instant)
                if targetPos then
                    teleportTo(targetPos)
                end
                
                -- LOOP FIRE PROMPT for the duration of farmDelay
                if brainrot then
                    firePromptLoop(brainrot, farmDelay)
                else
                    task.wait(farmDelay)
                end
                
                -- Return to base: First TP to Zones["1"], then tween to base
                if zones and zones:FindFirstChild("1") then
                    local zone1 = zones["1"]
                    if zone1:IsA("BasePart") then
                        teleportTo(zone1.Position)
                    elseif zone1:IsA("Model") and zone1:FindFirstChildWhichIsA("BasePart") then
                        teleportTo(zone1:FindFirstChildWhichIsA("BasePart").Position)
                    end
                end
                
                -- Tween back to base position
                tweenTo(Vector3.new(16, -10, -57))
                
                -- Small delay before next iteration
                task.wait(0.1)
            end
        end
        
        task.wait(0.1)
    end
end

-- Create Toggle
autoFarmToggle = MainTab:CreateToggle({
