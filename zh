local LocalPlayer = Players.LocalPlayer

-- SETTINGS
local AutoFarm = false
local Mode = "Behind"
local Distance = 5
local ToolSpam = false
local TargetNPC = true
local TargetPlayer = false

-- Store original gravity
local OriginalGravity = Workspace.Gravity

-- Tween tracking
local CurrentTween = nil

-- OFFSET
local function GetOffset(cf)
    if Mode == "Behind" then
        return cf * CFrame.new(0, 0, Distance)
    elseif Mode == "Under" then
        return cf * CFrame.new(0, -Distance, 0)
    elseif Mode == "Above" then
        return cf * CFrame.new(0, Distance, 0)
    end
end

-- 🔥 TOOL SPAM (IMPROVED)
task.spawn(function()
    while true do
        task.wait(0.05)
        if ToolSpam then
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    for _, tool in pairs(char:GetChildren()) do
                        if tool:IsA("Tool") then
                            pcall(function()
                                if tool.Parent == char then
                                    tool:Activate()
                                end
                            end)
                        end
                    end
                end
            end
        end
    end
end)

-- 🔥 CHECK IF MODEL IS VALID TARGET
local function IsValidTarget(model)
    if not model or not model:IsA("Model") then return false end
    if model == LocalPlayer.Character then return false end
    if model.Name == LocalPlayer.Name then return false end
    
    local hum = model:FindFirstChildOfClass("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart")
    
    if not hum or not hrp then return false end
    if hum.Health <= 0 then return false end
    if hrp.Position.Y <= -50 then return false end
    
    local player = Players:GetPlayerFromCharacter(model)
    
    -- Check toggles
    if player then
        return TargetPlayer -- Is player and we want players
    else
        return TargetNPC -- Is NPC and we want NPCs
    end
end

-- 🔥 FIND TARGET
local function GetTarget()
    -- Check players first if enabled
    if TargetPlayer then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local char = player.Character
                if char and IsValidTarget(char) then
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hum and hrp then
                        return hum, hrp
                    end
                end
            end
        end
    end
    
    -- Check NPCs if enabled
    if TargetNPC then
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and v.Name ~= "R6n_w1201s" then
                if IsValidTarget(v) then
                    local hum = v:FindFirstChildOfClass("Humanoid")
                    local hrp = v:FindFirstChild("HumanoidRootPart")
                    if hum and hrp then
                        -- Make sure it's not a player
                        if not Players:GetPlayerFromCharacter(v) then
                            return hum, hrp
                        end
                    end
                end
            end
        end
    end
    
    return nil, nil
end

-- 🚀 TWEEN TO TARGET
local CurrentTarget = nil
local CurrentHRP = nil

local function TweenToTarget(targetHRP)
    local char = LocalPlayer.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Cancel existing tween
    if CurrentTween then
        CurrentTween:Cancel()
        CurrentTween = nil
    end
    
    local targetCF = GetOffset(targetHRP.CFrame)
    local distance = (root.Position - targetCF.Position).Magnitude
    local tweenTime = math.clamp(distance / 100, 0.1, 0.5) -- Faster for close, slower for far
    
    local tweenInfo = TweenInfo.new(
        tweenTime,
        Enum.EasingStyle.Linear,
        Enum.EasingDirection.Out,
        0,
        false,
        0
    )
    
    local goal = {CFrame = targetCF}
    CurrentTween = TweenService:Create(root, tweenInfo, goal)
    CurrentTween:Play()
end

-- 🔥 MAIN LOOP
RunService.Heartbeat:Connect(function()
    if not AutoFarm then 
        if CurrentTween then
            CurrentTween:Cancel()
            CurrentTween = nil
        end
        CurrentTarget = nil
        CurrentHRP = nil
        return 
    end

    local char = LocalPlayer.Character
    if not char then 
        if CurrentTween then
            CurrentTween:Cancel()
            CurrentTween = nil
        end
        CurrentTarget = nil
        CurrentHRP = nil
        return 
    end

    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then 
        if CurrentTween then
            CurrentTween:Cancel()
            CurrentTween = nil
        end
        CurrentTarget = nil
        CurrentHRP = nil
        return 
    end

    -- Check if current target is still valid
    if CurrentTarget and CurrentHRP then
        if CurrentTarget.Health <= 0 or CurrentHRP.Position.Y <= -50 or not CurrentHRP.Parent then
            -- Target dead or gone, find new one
            CurrentTarget = nil
            CurrentHRP = nil
            if CurrentTween then
                CurrentTween:Cancel()
                CurrentTween = nil
            end
        end
    end

    -- Get new target if needed
    if not CurrentTarget or not CurrentHRP then
        local hum, hrp = GetTarget()
        if hum and hrp then
            CurrentTarget = hum
            CurrentHRP = hrp
            -- Start tweening to new target
            TweenToTarget(hrp)
        else
            CurrentTarget = nil
            CurrentHRP = nil
        end
    else
        -- Update tween to follow moving target
        if CurrentHRP and CurrentHRP.Parent then
            -- Check if we need to update tween (target moved significantly)
            local targetCF = GetOffset(CurrentHRP.CFrame)
            local distance = (root.Position - targetCF.Position).Magnitude
            
            -- Retween if target moved too far or tween finished
            if distance > 5 or not CurrentTween or CurrentTween.PlaybackState == Enum.PlaybackState.Completed then
                TweenToTarget(CurrentHRP)
            end
        end
    end
    
    -- Reset velocity while farming
    root.Velocity = Vector3.new(0, 0, 0)
    root.RotVelocity = Vector3.new(0, 0, 0)
end)

